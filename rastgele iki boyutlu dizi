import java.util.Arrays;
import java.util.Random;
import java.util.Scanner;

public class ikibooyutlumetot {
/**
iki boyutlu dizileri m çarpı en boyutunda rastgele sayıllardan oluşturup döndürme
*/

public static void main(String[] args) {
    int[][] sonuc= rastgele();
    System.out.print(Arrays.deepToString(sonuc));
        
    }
    public static int[][] rastgele() {
        Scanner input = new Scanner (System.in);
        System.out.print("satır sayısını gir: ");
        int m= input.nextInt();
        System.out.print("sütun sayısnı gir: ");
        int n= input.nextInt();
        
        Random rnd = new Random();
        int[][] dizi= new int[m][n];
        
        for (int i = 0; i <m; i++) {
            for (int j = 0; j < n; j++) {
                dizi[i][j]=rnd.nextInt();
            }
        }
        return dizi;        
    }    
}
